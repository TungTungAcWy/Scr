            if type(v) == "table" then for _, l in pairs(v) do pcall(function() l:Remove() end) end
            elseif typeof(v) == "Instance" then pcall(function() v:Destroy() end)
            else pcall(function() v:Remove() end) end
        end
        espCache[plr] = nil
