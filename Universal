local function create(ty, prop) local obj = Drawing.new(ty) for i, v in pairs(prop) do obj[i] = v end return obj end

local function isVisible(part, character)
    if not espWall then return true end
    local castParams = RaycastParams.new()
    castParams.FilterDescendantsInstances = {lp.Character, character, camera}
    castParams.FilterType = Enum.RaycastFilterType.Exclude
    local raycastResult = workspace:Raycast(camera.CFrame.Position, (part.Position - camera.CFrame.Position), castParams)
    return raycastResult == nil
end

